<Window
    x:Class="WhisperGUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WhisperGUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Whisper GUI">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <!-- Drag and Drop Overlay -->
        <Grid x:Name="DragDropOverlay" 
              AllowDrop="True" 
              DragOver="Grid_DragOver" 
              DragLeave="Grid_DragLeave"
              Drop="Grid_Drop"
              Background="Transparent"
              Canvas.ZIndex="100">
            <Border x:Name="DropHighlight" 
                    BorderBrush="{ThemeResource SystemAccentColor}" 
                    BorderThickness="4" 
                    CornerRadius="8" 
                    Visibility="Collapsed" 
                    Background="#33000000" 
                    Margin="10">
                <TextBlock Text="松开以转录文件" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{ThemeResource SystemAccentColor}"/>
            </Border>
        </Grid>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header and Controls -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
                <Button x:Name="RecordButton" 
                        Click="RecordButton_Click" 
                        Style="{StaticResource AccentButtonStyle}"
                        Width="150" Height="50">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon x:Name="RecordIcon" Glyph="&#xE720;" /> <!-- Microphone icon -->
                        <TextBlock x:Name="RecordText" Text="开始录音" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="模型状态: " FontWeight="Bold"/>
                    <TextBlock x:Name="ModelStatusText" Text="加载中..." Foreground="Gray"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="直接拖拽 音频/视频 文件到窗口即可进行离线转录" Foreground="Gray" FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>

            <!-- Transcription Output -->
            <TextBox x:Name="OutputTextBox" 
                     Grid.Row="1" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     IsReadOnly="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     PlaceholderText="识别结果将显示在这里..."/>

            <!-- Footer Controls -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,20,0,0" HorizontalAlignment="Right">
                <Button Content="复制文本" Click="CopyButton_Click"/>
                <Button Content="清空" Click="ClearButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
